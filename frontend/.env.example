# Build-time API base URL. Cloudflare Pages: set this in the project's
# Environment Variables section before deploy. Local dev leaves it unset
# and uses the Vite proxy (see vite.config.js).
VITE_API_BASE_URL=
# Socket.io URL. Same rule as above — leave empty in dev (Vite proxies),
# set to https://api.your-domain.com in production.
VITE_SOCKET_URL=
