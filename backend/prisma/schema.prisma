// SalesAutomation — full schema for all phases.
// Single-tenant per deploy in v1; tenant_id columns are present so the
// schema is forward-compatible with multi-tenant later.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Enums ───────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
  VIEWER
}

enum ConversationState {
  NEW
  ACTIVE
  PAUSED // waiting on customer / human / demo without ending session
  DEMO_PENDING
  FOLLOWUP
  MANUAL
  CLOSED
}

enum ChatMode {
  AI
  MANUAL
}

enum MessageDirection {
  IN
  OUT
}

enum MessageSource {
  CUSTOMER
  AI
  AGENT
  SYSTEM
  // Outbound from a bulk-broadcast campaign (M5+). Distinct from AGENT so
  // analytics don't conflate human replies with broadcasts.
  CAMPAIGN
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum SessionEndReason {
  CAMPAIGN_REENTRY
  ADMIN_CLOSED
  MANUAL_RESET
}

enum ManualReason {
  AI_REPLY_LIMIT
  LOW_CONFIDENCE
  KEYWORD_TRIGGER
  ADMIN_FORCED
  GLOBAL_AI_OFF
  NEGATIVE_SENTIMENT
  // M11: AI drafted a Quotation; an operator must review + send. Money
  // artifacts never go out unattended.
  AI_QUOTATION_REVIEW
}

enum TemplateType {
  ONBOARDING_DEFAULT
  MANUAL_HANDOFF
  FALLBACK
  SESSION_RESUME
  DEMO_CONFIRMATION
}

// ─── CRM enums (M1) ──────────────────────────────────────────────────

enum StageCategory {
  OPEN
  WON
  LOST
}

enum LeadScore {
  HOT
  WARM
  COLD
  UNQUALIFIED
}

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
}

enum ActivityKind {
  MESSAGE
  NOTE
  TASK
  STAGE_CHANGE
  ASSIGNMENT
  TAG_CHANGE
  AUTOMATION
  CALL
}

// ─── Bulk campaign enums (M4) ────────────────────────────────────────

enum BulkCampaignStatus {
  DRAFT
  PENDING_APPROVAL
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

enum BulkRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  REPLIED
}

// ─── Automation enums (M6) ──────────────────────────────────────────

enum AutomationTrigger {
  NEW_LEAD
  STAGE_CHANGED
  LEAD_ASSIGNED
  NO_REPLY
  TAG_ADDED
  CAMPAIGN_REPLIED
  INBOUND_KEYWORD
  // M11: revenue events. Fire after a quotation transitions to ACCEPTED
  // (operator or webhook-driven) or after a PaymentLink is marked PAID.
  QUOTATION_ACCEPTED
  PAYMENT_RECEIVED
}

enum AutomationRunStatus {
  PENDING
  RUNNING
  WAITING
  DONE
  FAILED
  CANCELLED
}

// ─── Channels (M9 / M10) ─────────────────────────────────────────────

enum ChannelType {
  WHATSAPP
  INSTAGRAM
  FB_MESSENGER
  WEB_CHAT
}

// ─── Revenue (M11) ───────────────────────────────────────────────────

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  REVISED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  STUB
}

enum PaymentLinkStatus {
  CREATED
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
  CANCELLED
}

enum PaymentTxnStatus {
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PricingRuleKind {
  VOLUME_TIER
  SEGMENT
  TIME_BOUND
}

// ─── Tenant + Users ──────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  campaigns           Campaign[]
  kbGroups            KbGroup[]
  chats               Chat[]
  tags                Tag[]
  settings            Setting[]
  settingsAudit       SettingAuditLog[]
  messageTemplates    MessageTemplate[]
  contacts            Contact[]
  pipelines           Pipeline[]
  leads               Lead[]
  tasks               Task[]
  bulkCampaigns       BulkCampaign[]
  followupRules       FollowupRule[]
  automations         Automation[]
  notifications       Notification[]
  channels            Channel[]
  integrations        WebsiteIntegration[]
  // M11 revenue
  products            Product[]
  pricingRules        PricingRule[]
  quotations          Quotation[]
  quotationApprovals  QuotationApproval[]
  paymentLinks        PaymentLink[]
  paymentTransactions PaymentTransaction[]
  invoices            Invoice[]

  @@map("tenants")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String?
  role         Role      @default(AGENT)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notes              Note[]
  settingsAudit      SettingAuditLog[]
  manualClaimed      ManualQueueItem[]   @relation("ManualClaimedBy")
  uploads            KbDocument[]        @relation("KbUploadedBy")
  ownedContacts      Contact[]           @relation("ContactOwner")
  assignedLeads      Lead[]              @relation("LeadAssignee")
  assignedTasks      Task[]              @relation("TaskAssignee")
  createdTasks       Task[]              @relation("TaskCreator")
  leadActivities     LeadActivity[]
  bulkCampaigns      BulkCampaign[]      @relation("BulkCampaignCreator")
  approvedBulks      BulkCampaign[]      @relation("BulkCampaignApprover")
  followupRules      FollowupRule[]      @relation("FollowupRuleCreator")
  automations        Automation[]        @relation("AutomationCreator")
  notifications      Notification[]
  // M11 revenue authoring
  createdQuotations  Quotation[]         @relation("QuotationCreator")
  quotationApprovals QuotationApproval[] @relation("QuotationApprover")

  @@index([tenantId])
  @@map("users")
}

// ─── Campaigns ───────────────────────────────────────────────────────

model Campaign {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  name              String
  tag               String    @unique // CAMPAIGN_X92P
  isActive          Boolean   @default(true) @map("is_active")
  expiresAt         DateTime? @map("expires_at")
  onboardingMessage String    @map("onboarding_message")
  // Optional friendly text appended after the tag in the wa.me ?text=
  // prefill (e.g. "Hi, I want to know about pricing"). Customers see the
  // combined string in WhatsApp and tap send. Matching still happens on
  // the first token = tag, so customer edits don't break the trigger.
  entryMessage      String?   @map("entry_message")
  formLink          String?   @map("form_link")
  businessType      String?   @map("business_type")
  // Seeded operator-only campaign(s) (e.g. CAMPAIGN_TEST_INTERNAL).
  // Cannot be deleted; tag + name are locked. Used to verify QR
  // reconnection, provider switches, and end-to-end flow without
  // touching live campaigns.
  isSystem          Boolean   @default(false) @map("is_system")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kbGroups     CampaignKbGroup[]
  chatSessions ChatSession[]
  leads        Lead[]

  @@index([tenantId])
  @@index([isActive])
  @@map("campaigns")
}

model CampaignKbGroup {
  campaignId String @map("campaign_id")
  kbGroupId  String @map("kb_group_id")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  kbGroup  KbGroup  @relation(fields: [kbGroupId], references: [id], onDelete: Cascade)

  @@id([campaignId, kbGroupId])
  @@map("campaign_kb_groups")
}

// ─── Knowledge Base ──────────────────────────────────────────────────

model KbGroup {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  name                String
  description         String?
  confidenceThreshold Float    @default(0.82) @map("confidence_threshold")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents KbDocument[]
  campaigns CampaignKbGroup[]

  @@index([tenantId])
  @@map("kb_groups")
}

model KbDocument {
  id           String         @id @default(cuid())
  kbGroupId    String         @map("kb_group_id")
  filename     String
  filePath     String         @map("file_path")
  status       DocumentStatus @default(PENDING)
  errorMessage String?        @map("error_message")
  uploadedById String?        @map("uploaded_by_id")
  // Lightweight versioning. Replacing a doc creates a new row with
  // version+1; the previous row is marked is_active=false. Retrieval
  // filters on is_active=true.
  version      Int            @default(1)
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  kbGroup    KbGroup   @relation(fields: [kbGroupId], references: [id], onDelete: Cascade)
  uploadedBy User?     @relation("KbUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  chunks     KbChunk[]

  @@index([kbGroupId, isActive])
  @@map("kb_documents")
}

model KbChunk {
  id                String                       @id @default(cuid())
  documentId        String                       @map("document_id")
  chunkIndex        Int                          @map("chunk_index")
  text              String
  // pgvector column. All providers must produce 1536-dim vectors (OpenAI
  // text-embedding-3-small natively; Gemini embedding-001 with
  // outputDimensionality=1536). Switching providers requires re-embedding,
  // tracked via `embedding_provider` below.
  embedding         Unsupported("vector(1536)")?
  // Which provider + exact model produced this vector. Retrieval filters
  // on (provider, model) so a mid-flight provider OR model upgrade
  // doesn't compare across embedding spaces.
  embeddingProvider String?                      @map("embedding_provider")
  embeddingModel    String?                      @map("embedding_model")
  // tsvector generated column + GIN index added in db-init.js as raw SQL
  // (Postgres-specific; not expressible in Prisma DSL).
  createdAt         DateTime                     @default(now()) @map("created_at")

  document KbDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([embeddingProvider, embeddingModel])
  @@map("kb_chunks")
}

// ─── Chats / Sessions / Messages ─────────────────────────────────────

model Chat {
  id                  String    @id @default(cuid())
  tenantId            String    @map("tenant_id")
  phone               String // E.164 (e.g. "919999999999")
  displayName         String?   @map("display_name")
  currentSessionId    String?   @map("current_session_id")
  processingLockUntil DateTime? @map("processing_lock_until")
  lastMessageAt       DateTime? @map("last_message_at")
  // Soft FK to the CRM Contact identity. Nullable because inbound messages
  // can arrive before a Contact row exists (the inbound worker upserts and
  // backfills this on first message). Source of truth for phone stays on
  // chats.phone — see backfill script.
  contactId           String?   @map("contact_id")
  // M9: which channel did this chat originate on? Backfilled to the
  // tenant's WHATSAPP channel on migration; web-chat sessions get the
  // WEB_CHAT channel. Nullable so old rows don't fail the migration.
  channelId           String?   @map("channel_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact          Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  channel          Channel?          @relation(fields: [channelId], references: [id], onDelete: SetNull)
  sessions         ChatSession[]
  notes            Note[]
  tags             ChatTag[]
  manualQueueItems ManualQueueItem[]
  demoBookings     DemoBooking[]

  @@unique([tenantId, phone])
  @@index([lastMessageAt])
  @@index([contactId])
  @@index([channelId])
  @@map("chats")
}

model ChatSession {
  id             String            @id @default(cuid())
  chatId         String            @map("chat_id")
  campaignId     String?           @map("campaign_id")
  state          ConversationState @default(NEW)
  mode           ChatMode          @default(AI)
  // Increments ONLY when an outbound message with source=AI is committed.
  // Customer inbound, agent reply, system messages do NOT count.
  aiReplyCount   Int               @default(0) @map("ai_reply_count")
  startedAt      DateTime          @default(now()) @map("started_at")
  // Bumped on every inbound and outbound. Drives the 7-day reset rule.
  lastActivityAt DateTime          @default(now()) @map("last_activity_at")
  // Snapshot fields — denormalized for fast debug reads. Updated when an
  // AI reply is sent.
  lastConfidence Float?            @map("last_confidence")
  lastAiReplyAt  DateTime?         @map("last_ai_reply_at")
  // Which AI provider produced the most recent AI reply on this session.
  // Useful for debugging, analytics, and per-provider billing roll-ups.
  aiProvider     String?           @map("ai_provider")
  endedAt        DateTime?         @map("ended_at")
  endedReason    SessionEndReason? @map("ended_reason")

  chat             Chat              @relation(fields: [chatId], references: [id], onDelete: Cascade)
  campaign         Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  messages         Message[]
  manualQueueItems ManualQueueItem[]

  // Active-session lookup uses (chatId, endedAt IS NULL).
  @@index([chatId, endedAt])
  @@index([campaignId])
  @@map("chat_sessions")
}

model Message {
  id          String           @id @default(cuid())
  sessionId   String           @map("session_id")
  direction   MessageDirection
  source      MessageSource
  body        String
  // KB chunk ids (kb_chunks.id) that grounded this AI reply (empty for non-AI sources).
  kbChunkIds  String[]         @map("kb_chunk_ids")
  confidence  Float?
  // For inbound dedup against whatsapp-web.js retries.
  waMessageId String?          @unique @map("wa_message_id")
  // Set when an OUT message is actually delivered to WhatsApp. The wa-worker
  // checks `sent_at IS NULL` before sending to prevent duplicate sends on
  // queue retries. Combined with BullMQ jobId="out-<messageId>", this is
  // the outbound-deduplication mechanism.
  sentAt      DateTime?        @map("sent_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  session        ChatSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  leadActivities LeadActivity[]
  bulkRecipients BulkCampaignRecipient[]
  followupLogs   FollowupLog[]

  @@index([sessionId, createdAt])
  @@map("messages")
}

// ─── Tags / Notes ────────────────────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  color     String?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chats  ChatTag[]

  @@unique([tenantId, name])
  @@map("tags")
}

model ChatTag {
  chatId String @map("chat_id")
  tagId  String @map("tag_id")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([chatId, tagId])
  @@map("chat_tags")
}

model Note {
  id        String   @id @default(cuid())
  chatId    String   @map("chat_id")
  authorId  String?  @map("author_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  chat           Chat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
  author         User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  leadActivities LeadActivity[]

  @@index([chatId])
  @@map("notes")
}

// ─── Settings ────────────────────────────────────────────────────────

model Setting {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  key         String
  value       Json
  // True when `value` holds an AES-256-GCM ciphertext envelope. The crypto
  // util transparently encrypts/decrypts based on this flag.
  encrypted   Boolean  @default(false)
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("settings")
}

model SettingAuditLog {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  key         String
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  changedById String?  @map("changed_by_id")
  changedAt   DateTime @default(now()) @map("changed_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  changedBy User?  @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([tenantId, key])
  @@index([changedAt])
  @@map("settings_audit_logs")
}

// ─── Message Templates ───────────────────────────────────────────────
// Replaces hardcoded reply strings (handoff, fallback, resume, demo) in
// settings. Per-tenant; seeded with sensible defaults.

model MessageTemplate {
  id        String       @id @default(cuid())
  tenantId  String       @map("tenant_id")
  name      String // unique key per tenant (e.g. "manual_handoff")
  type      TemplateType
  content   String
  // Placeholder names allowed in `content`, e.g. ["customer_name", "demo_link"].
  variables String[]     @default([])
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId, type])
  @@map("message_templates")
}

// ─── Manual Queue + Demo Bookings ────────────────────────────────────

model ManualQueueItem {
  id          String       @id @default(cuid())
  chatId      String       @map("chat_id")
  sessionId   String       @map("session_id")
  reason      ManualReason
  createdAt   DateTime     @default(now()) @map("created_at")
  claimedById String?      @map("claimed_by_id")
  claimedAt   DateTime?    @map("claimed_at")
  resolvedAt  DateTime?    @map("resolved_at")

  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  claimedBy User?       @relation("ManualClaimedBy", fields: [claimedById], references: [id], onDelete: SetNull)

  @@index([resolvedAt])
  @@index([chatId])
  @@map("manual_queue_items")
}

model DemoBooking {
  id             String   @id @default(cuid())
  chatId         String   @map("chat_id")
  teamsMeetingId String?  @map("teams_meeting_id")
  teamsJoinUrl   String?  @map("teams_join_url")
  scheduledAt    DateTime @map("scheduled_at")
  createdAt      DateTime @default(now()) @map("created_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("demo_bookings")
}

// ─── CRM: Contacts, Pipelines, Leads, Tasks (M1) ─────────────────────
// Contact = person identity (CRM record). Chat is per-phone conversation
// state; a Contact may exist without ever messaging. chats.contactId is
// nullable and backfilled by the inbound worker on first message.

model Contact {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  // E.164 (e.g. "919999999999"), matches chats.phone.
  mobile       String
  email        String?
  company      String?
  city         String?
  state        String?
  country      String?
  source       String?
  ownerId      String?   @map("owner_id")
  // Free-form per-tenant extensions. Schemaless on purpose — every CRM
  // grows custom fields and modeling each one as a column doesn't scale.
  customFields Json?     @map("custom_fields")
  // Soft delete: Lead history references the contact, so we keep the row
  // but mark it deleted. Active queries filter `deletedAt IS NULL`.
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner          User?                   @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  chats          Chat[]
  leads          Lead[]
  bulkRecipients BulkCampaignRecipient[]
  quotations     Quotation[]
  paymentLinks   PaymentLink[]

  // Mobile is the canonical identity per tenant. Email is optional, indexed
  // but not unique (one household may share an email across two contacts).
  @@unique([tenantId, mobile])
  @@index([tenantId, email])
  @@index([tenantId, ownerId])
  @@index([tenantId, source])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@map("contacts")
}

model Pipeline {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  // Per-tenant default. Enforced via a partial unique index added in
  // db-init.js: UNIQUE (tenant_id) WHERE is_default. New leads land in
  // the default pipeline unless an explicit pipelineId is provided.
  isDefault Boolean  @default(false) @map("is_default")
  // Seeded pipelines (e.g. "Sales") cannot be deleted; mirrors the
  // Campaign.isSystem semantics.
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages Stage[]
  leads  Lead[]

  @@index([tenantId])
  @@map("pipelines")
}

model Stage {
  id         String        @id @default(cuid())
  pipelineId String        @map("pipeline_id")
  name       String
  // Integer with gaps of 10 (e.g. 10, 20, 30) so drag-drop reorder is a
  // single UPDATE instead of N. Not unique — duplicates during reorder
  // are tolerated and resolved on next save.
  order      Int
  // Drives KPIs without parsing stage names. OPEN = in pipeline, WON =
  // converted, LOST = dropped.
  category   StageCategory @default(OPEN)
  color      String?
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  pipeline       Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads          Lead[]
  activitiesFrom LeadActivity[] @relation("StageFrom")
  activitiesTo   LeadActivity[] @relation("StageTo")

  @@index([pipelineId, order])
  @@map("stages")
}

model Lead {
  id            String     @id @default(cuid())
  tenantId      String     @map("tenant_id")
  contactId     String     @map("contact_id")
  pipelineId    String     @map("pipeline_id")
  stageId       String     @map("stage_id")
  source        String?
  // Optional link to the existing INBOUND tag-routed campaign (NOT the
  // M5 bulk outbound campaign — that lives in its own table).
  campaignId    String?    @map("campaign_id")
  assignedToId  String?    @map("assigned_to_id")
  // Agent-facing bucket. The numeric aiScore (0–1) is the M8 AI output
  // that feeds this bucket via a threshold mapping.
  score         LeadScore?
  aiScore       Float?     @map("ai_score")
  expectedValue Decimal?   @map("expected_value") @db.Decimal(12, 2)
  currency      String?    @db.VarChar(3)
  lostReason    String?    @map("lost_reason")
  wonAt         DateTime?  @map("won_at")
  // M9: marketing-attribution snapshot captured at lead creation (e.g.
  // by the web-chat widget reading window.location.search). Nullable —
  // most leads come in without these. analytics.getSourceBreakdown reads
  // lead.source for cohort grouping; UTMs add finer granularity.
  utmSource     String?    @map("utm_source")
  utmMedium     String?    @map("utm_medium")
  utmCampaign   String?    @map("utm_campaign")
  adId          String?    @map("ad_id")
  landingPage   String?    @map("landing_page")
  referrer      String?
  lostAt        DateTime?  @map("lost_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact        Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  pipeline       Pipeline        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  // Inbound campaign that originated this lead (WhatsApp tag-routed).
  // SetNull on cascade so deleting a campaign doesn't orphan the lead.
  campaign       Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  stage          Stage           @relation(fields: [stageId], references: [id])
  assignedTo     User?           @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  tasks          Task[]
  activities     LeadActivity[]
  followupLogs   FollowupLog[]
  automationRuns AutomationRun[]
  memory         LeadMemory?
  quotations     Quotation[]

  @@index([tenantId, pipelineId, stageId])
  @@index([tenantId, assignedToId, stageId])
  @@index([tenantId, score])
  @@index([contactId])
  @@index([campaignId])
  @@index([tenantId, createdAt])
  @@map("leads")
}

// Per-lead timeline. Each row is one event (message, note, stage change,
// etc.) with all entity FKs nullable. Querying by `kind` is the hot path;
// joins through the populated FK return the entity detail without a
// polymorphic lookup.
model LeadActivity {
  id          String       @id @default(cuid())
  leadId      String       @map("lead_id")
  kind        ActivityKind
  messageId   String?      @map("message_id")
  taskId      String?      @map("task_id")
  noteId      String?      @map("note_id")
  stageFromId String?      @map("stage_from_id")
  stageToId   String?      @map("stage_to_id")
  actorId     String?      @map("actor_id")
  // Free-form payload for kinds that don't slot into the FKs above
  // (e.g. AUTOMATION carries the automation run id + step index).
  data        Json?
  createdAt   DateTime     @default(now()) @map("created_at")

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  message   Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  note      Note?    @relation(fields: [noteId], references: [id], onDelete: SetNull)
  stageFrom Stage?   @relation("StageFrom", fields: [stageFromId], references: [id], onDelete: SetNull)
  stageTo   Stage?   @relation("StageTo", fields: [stageToId], references: [id], onDelete: SetNull)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt(sort: Desc)])
  @@index([kind])
  @@map("lead_activities")
}

model Task {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  leadId       String?    @map("lead_id")
  title        String
  description  String?
  dueAt        DateTime?  @map("due_at")
  status       TaskStatus @default(OPEN)
  doneAt       DateTime?  @map("done_at")
  assignedToId String?    @map("assigned_to_id")
  createdById  String?    @map("created_by_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead           Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedTo     User?          @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy      User?          @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  leadActivities LeadActivity[]

  @@index([tenantId, assignedToId, status, dueAt])
  @@index([leadId])
  @@map("tasks")
}

// ─── Bulk Campaigns (M4) ─────────────────────────────────────────────
// Outbound broadcast model. Distinct from `Campaign` (which is INBOUND
// tag-routed). Recipients are materialized rows; the drip scheduler reads
// PENDING rows in batches respecting delay/jitter/daily caps and warmup.
//
// Approval flow: DRAFT → PENDING_APPROVAL → SCHEDULED → RUNNING →
// COMPLETED/CANCELLED. Operators can PAUSE a RUNNING bulk to halt the
// drip without losing already-sent recipients.

model BulkCampaign {
  id               String             @id @default(cuid())
  tenantId         String             @map("tenant_id")
  name             String
  messageBody      String             @map("message_body")
  mediaUrl         String?            @map("media_url")
  mediaType        String?            @map("media_type")
  status           BulkCampaignStatus @default(DRAFT)
  scheduledAt      DateTime?          @map("scheduled_at")
  // Safety: hard caps the producer enforces in addition to any global
  // warmup gate. dailyLimit applies per-tenant across this bulk's recipients;
  // delayMin/delayMax are seconds between drips (jittered uniformly).
  dailyLimit       Int                @default(500) @map("daily_limit")
  delayMin         Int                @default(30) @map("delay_min")
  delayMax         Int                @default(60) @map("delay_max")
  // ISO-8601 local times (e.g. "22:00" / "08:00"). Recipients whose tick
  // would fall inside this window are deferred to the next allowed slot.
  quietHoursStart  String?            @map("quiet_hours_start")
  quietHoursEnd    String?            @map("quiet_hours_end")
  // Skip recipients whose contact has an INBOUND message within this many
  // hours of the planned send. 0 disables the skip.
  skipRepliedHours Int                @default(0) @map("skip_replied_hours")
  // Seeded operator-only campaigns (mirrors Campaign.isSystem semantics).
  isSystem         Boolean            @default(false) @map("is_system")
  createdById      String?            @map("created_by_id")
  approvedById     String?            @map("approved_by_id")
  approvedAt       DateTime?          @map("approved_at")
  startedAt        DateTime?          @map("started_at")
  completedAt      DateTime?          @map("completed_at")
  // Track recipient counts denormalized for fast list views. The drip
  // worker updates these atomically when transitioning recipient status.
  sentCount        Int                @default(0) @map("sent_count")
  deliveredCount   Int                @default(0) @map("delivered_count")
  readCount        Int                @default(0) @map("read_count")
  failedCount      Int                @default(0) @map("failed_count")
  repliedCount     Int                @default(0) @map("replied_count")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User?                   @relation("BulkCampaignCreator", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy User?                   @relation("BulkCampaignApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  recipients BulkCampaignRecipient[]

  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, createdAt])
  @@map("bulk_campaigns")
}

model BulkCampaignRecipient {
  id             String              @id @default(cuid())
  bulkCampaignId String              @map("bulk_campaign_id")
  contactId      String              @map("contact_id")
  // Link to the materialized message row once the drip enqueues it.
  // Nullable while PENDING; set on transition to QUEUED.
  messageId      String?             @map("message_id")
  status         BulkRecipientStatus @default(PENDING)
  error          String?
  // Idempotent send: the drip worker writes plannedAt when picking the row
  // so concurrent ticks don't double-enqueue. messageId+sentAt is the
  // ultimate dedup via the shared outbound rail.
  plannedAt      DateTime?           @map("planned_at")
  queuedAt       DateTime?           @map("queued_at")
  sentAt         DateTime?           @map("sent_at")
  deliveredAt    DateTime?           @map("delivered_at")
  readAt         DateTime?           @map("read_at")
  repliedAt      DateTime?           @map("replied_at")
  failedAt       DateTime?           @map("failed_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  bulkCampaign BulkCampaign @relation(fields: [bulkCampaignId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  message      Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@unique([bulkCampaignId, contactId])
  @@index([bulkCampaignId, status])
  @@index([messageId])
  @@index([status, plannedAt])
  @@map("bulk_campaign_recipients")
}

// ─── Auto follow-up engine (M5) ──────────────────────────────────────
// Operator-defined rules that fire when a lead has been idle in a given
// stage for N hours. Rules are evaluated by the followup-tick scheduler
// job. Each fire writes a FollowupLog so we can enforce maxReminders
// without scanning LeadActivity (which would require a JSON predicate).

model FollowupRule {
  id                    String   @id @default(cuid())
  tenantId              String   @map("tenant_id")
  name                  String
  isActive              Boolean  @default(true) @map("is_active")
  // Optional pipeline + stage filter. Null = match any pipeline /
  // any stage in the tenant. Both null = "all leads".
  pipelineId            String?  @map("pipeline_id")
  stageId               String?  @map("stage_id")
  // Idle threshold — hours since the chat's lastMessageAt (any direction).
  // Using lastMessageAt rather than last-inbound prevents stacking reminders
  // within the threshold window.
  hoursSinceLastInbound Int      @map("hours_since_last_inbound")
  // The MessageTemplate.name that produces the reminder body. We don't FK
  // on name (templates can be renamed); resolve at fire time.
  templateName          String   @map("template_name")
  maxReminders          Int      @default(1) @map("max_reminders")
  quietHoursStart       String?  @map("quiet_hours_start")
  quietHoursEnd         String?  @map("quiet_hours_end")
  createdById           String?  @map("created_by_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?         @relation("FollowupRuleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  logs      FollowupLog[]

  @@index([tenantId, isActive])
  @@map("followup_rules")
}

model FollowupLog {
  id        String   @id @default(cuid())
  ruleId    String   @map("rule_id")
  leadId    String   @map("lead_id")
  messageId String?  @map("message_id")
  error     String?
  sentAt    DateTime @default(now()) @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")

  rule    FollowupRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  lead    Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  message Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([ruleId, leadId])
  @@index([leadId])
  @@index([sentAt])
  @@map("followup_logs")
}

// ─── Workflow Automation (M6) ────────────────────────────────────────
// Operator-defined event-triggered workflows. Each Automation has one
// trigger (event source), optional config filter, and a definition (JSON
// step array). When the trigger fires, an AutomationRun row is created
// and the automation-runs worker progresses one step per BullMQ job.
//
// Step types (v1):
//   WAIT          — reschedule the next step after `minutes`
//   SEND_MESSAGE  — render a named template + enqueue OUTGOING (SYSTEM)
//   ASSIGN        — set lead.assignedToId
//   ADD_TAG       — attach tag to the lead's contact's chats
//   MOVE_STAGE    — set lead.stageId (emits STAGE_CHANGED event)
//   CREATE_TASK   — make a Task linked to the lead
//   IF            — guard: continue only if condition holds; else END run

model Automation {
  id            String            @id @default(cuid())
  tenantId      String            @map("tenant_id")
  name          String
  isActive      Boolean           @default(true) @map("is_active")
  trigger       AutomationTrigger
  // Optional filter — narrows which firings of the trigger actually fire
  // this automation. Shape depends on the trigger; e.g. for NEW_LEAD:
  // { source: "webform" }. Null = no filter.
  triggerConfig Json?             @map("trigger_config")
  // Step array. See the comment above for the shape.
  definition    Json
  createdById   String?           @map("created_by_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("AutomationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  runs      AutomationRun[]

  @@index([tenantId, isActive])
  @@index([tenantId, trigger])
  @@map("automations")
}

model AutomationRun {
  id           String              @id @default(cuid())
  automationId String              @map("automation_id")
  leadId       String?             @map("lead_id")
  chatId       String?             @map("chat_id")
  contactId    String?             @map("contact_id")
  status       AutomationRunStatus @default(PENDING)
  // Index of the next step to execute (0-based). On completion equals
  // definition.steps.length.
  currentStep  Int                 @default(0) @map("current_step")
  // Mutable per-run state; carries step outputs forward (e.g. SEND_MESSAGE
  // can stash the message id here for downstream IF checks).
  context      Json?
  startedAt    DateTime            @default(now()) @map("started_at")
  finishedAt   DateTime?           @map("finished_at")
  error        String?

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  lead       Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([automationId, status])
  @@index([leadId])
  @@index([status])
  @@map("automation_runs")
}

// ─── Lead memory (M7) ────────────────────────────────────────────────
// Long-running "what we know about this lead" facts extracted by the AI
// from the conversation. Schemaless JSON because the shape varies by
// product (budget, preferred_language, last_objection, interested_product,
// etc.). One row per lead — the scoring/suggested-reply jobs read it as
// context, and update it after each scoring pass.

model LeadMemory {
  id        String   @id @default(cuid())
  leadId    String   @unique @map("lead_id")
  memory    Json     @default("{}")
  // Bumped on each successful AI update — lets the UI surface "we just
  // learned something new" without diffing the whole object.
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_memory")
}

// ─── In-app notifications (M8) ──────────────────────────────────────
// Per-user notifications surfaced via the bell icon in the AppShell.
// `kind` is a free-form string (e.g. "LEAD_ASSIGNED", "FOLLOWUP_SENT")
// so adding new sources doesn't require schema changes. Optional links
// (leadId, chatId, url) let the UI route on click.

model Notification {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  userId    String    @map("user_id")
  kind      String
  title     String
  body      String?
  // Soft references to common entities. If the entity is deleted, the
  // notification just becomes un-clickable; we don't cascade.
  leadId    String?   @map("lead_id")
  chatId    String?   @map("chat_id")
  url       String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([tenantId, createdAt])
  @@map("notifications")
}

// ─── Channels (M9 web chat / M10 Meta) ──────────────────────────────
// One row per provider integration per tenant. WhatsApp ships out of the
// box; web-chat is a built-in. Instagram + FB Messenger arrive in M10
// using the same shape with provider-specific config blobs.

model Channel {
  id        String      @id @default(cuid())
  tenantId  String      @map("tenant_id")
  type      ChannelType
  name      String
  // Per-provider config (e.g. Meta page id + access token for FB).
  // Encrypted-at-rest via the existing settings-style envelope when the
  // operator marks it sensitive; the column is JSON for forward-compat.
  config    Json?
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chats  Chat[]

  @@unique([tenantId, type])
  @@map("channels")
}

// ─── Website Integrations (public API + embeddable widget) ──────────
// One row per "website embedding the widget OR calling our public API".
// The apiKey is the credential — operators paste it into their site or
// pass it in API requests. allowedDomains is a CORS-style allowlist
// matched against the request's Origin / Referer. widgetConfig drives
// the widget's appearance (colors, position, welcome text, etc.) so a
// single embed.js can render differently per integration.

model WebsiteIntegration {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  name               String
  // The credential. Generated server-side as a 32-byte hex token.
  // Unique globally (not just per-tenant) so the middleware can do
  // a cheap O(1) lookup without first resolving the tenant.
  apiKey             String   @unique @map("api_key")
  // Hostnames (no protocol, no path) that may use this key. Empty
  // array = no restriction (dev-only convenience; production should
  // always populate). Wildcards not supported in v1.
  allowedDomains     String[] @default([]) @map("allowed_domains")
  isActive           Boolean  @default(true) @map("is_active")
  widgetEnabled      Boolean  @default(true) @map("widget_enabled")
  // Per-key rate limit, applied by our public-api middleware. Stored
  // here (rather than a global setting) so different sites can have
  // different budgets.
  rateLimitPerMinute Int      @default(60) @map("rate_limit_per_minute")
  // Free-form JSON for widget appearance + behavior:
  // { primaryColor, position, welcomeText, whatsappNumber, logo,
  //   businessHoursTz, requireEmail, requirePhone, ... }
  widgetConfig       Json?    @map("widget_config")
  createdById        String?  @map("created_by_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("website_integrations")
}

// ─── Revenue: Products, Pricing, Quotations, Payments (M11) ─────────
// Catalog (Product) + ad-hoc lines drive Quotations. Quotation transitions
// emit lead stage moves via lead.service.moveLeadStage; payment-link
// transitions do the same on PAID. Money is always Decimal(14,2); never
// JS floats.

model Product {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  sku         String
  name        String
  description String?
  basePrice   Decimal       @map("base_price") @db.Decimal(14, 2)
  currency    String        @db.VarChar(3)
  taxRatePct  Decimal       @default(0) @map("tax_rate_pct") @db.Decimal(5, 2)
  status      ProductStatus @default(ACTIVE)
  metadata    Json?
  deletedAt   DateTime?     @map("deleted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lineItems QuotationLineItem[]

  @@unique([tenantId, sku])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@map("products")
}

// Lightweight discount/markup rules. config shape depends on kind:
//   VOLUME_TIER: { minQty: number, maxQty?: number, discountPct: number }
//   SEGMENT:     { tagId: string, discountPct: number }
//   TIME_BOUND:  { startsAt: ISO, endsAt: ISO, discountPct: number }
// Evaluation walks all active rules ordered by priority; the first match
// wins. v1 is intentionally simple — operators can compose multiple
// quotations rather than expressing complex stacked rules in config.
model PricingRule {
  id        String          @id @default(cuid())
  tenantId  String          @map("tenant_id")
  name      String
  kind      PricingRuleKind
  productId String?         @map("product_id") // null = applies to all
  config    Json
  priority  Int             @default(100)
  active    Boolean         @default(true)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, active, kind])
  @@map("pricing_rules")
}

model Quotation {
  id                String          @id @default(cuid())
  tenantId          String          @map("tenant_id")
  // Human-friendly number, generated via the {prefix}-{yyyy}-{seq} pattern
  // from settings. Unique per tenant.
  number            String
  leadId            String?         @map("lead_id")
  contactId         String          @map("contact_id")
  status            QuotationStatus @default(DRAFT)
  currency          String          @db.VarChar(3)
  subtotal          Decimal         @db.Decimal(14, 2)
  discountTotal     Decimal         @default(0) @map("discount_total") @db.Decimal(14, 2)
  taxTotal          Decimal         @default(0) @map("tax_total") @db.Decimal(14, 2)
  grandTotal        Decimal         @map("grand_total") @db.Decimal(14, 2)
  validUntil        DateTime        @map("valid_until")
  terms             String?
  notes             String?
  // Lightweight revision chain. A REVISE on an existing quote creates a
  // new row with version++ and parentQuotationId pointing at the source.
  version           Int             @default(1)
  parentQuotationId String?         @map("parent_quotation_id")
  // Optional storage path / URL to the rendered PDF. Local-disk in v1.
  pdfPath           String?         @map("pdf_path")
  sentAt            DateTime?       @map("sent_at")
  acceptedAt        DateTime?       @map("accepted_at")
  rejectedAt        DateTime?       @map("rejected_at")
  createdById       String?         @map("created_by_id")
  // AI drafted this quote and an operator must approve before /send.
  draftedByAi       Boolean         @default(false) @map("drafted_by_ai")
  deletedAt         DateTime?       @map("deleted_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lead         Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdBy    User?               @relation("QuotationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  parent       Quotation?          @relation("QuotationRevisions", fields: [parentQuotationId], references: [id], onDelete: SetNull)
  revisions    Quotation[]         @relation("QuotationRevisions")
  lineItems    QuotationLineItem[]
  approvals    QuotationApproval[]
  paymentLinks PaymentLink[]
  invoices     Invoice[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, leadId])
  @@index([tenantId, contactId])
  @@index([tenantId, validUntil])
  @@index([tenantId, createdAt])
  @@map("quotations")
}

model QuotationLineItem {
  id          String   @id @default(cuid())
  quotationId String   @map("quotation_id")
  // Null = ad-hoc line not tied to catalog. Preserve productId on revisions
  // even if the Product is later archived — historic quotes don't change.
  productId   String?  @map("product_id")
  // 0-based ordinal. Preserved across revisions so revised quotes maintain
  // line order.
  position    Int
  description String
  qty         Decimal  @db.Decimal(12, 3)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(14, 2)
  discountPct Decimal  @default(0) @map("discount_pct") @db.Decimal(5, 2)
  taxRatePct  Decimal  @default(0) @map("tax_rate_pct") @db.Decimal(5, 2)
  lineTotal   Decimal  @map("line_total") @db.Decimal(14, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quotationId, position])
  @@map("quotation_line_items")
}

model QuotationApproval {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenant_id")
  quotationId     String         @map("quotation_id")
  approverId      String?        @map("approver_id")
  status          ApprovalStatus @default(PENDING)
  thresholdAmount Decimal        @map("threshold_amount") @db.Decimal(14, 2)
  comment         String?
  requestedAt     DateTime       @default(now()) @map("requested_at")
  decidedAt       DateTime?      @map("decided_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  approver  User?     @relation("QuotationApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([quotationId])
  @@map("quotation_approvals")
}

model PaymentLink {
  id             String            @id @default(cuid())
  tenantId       String            @map("tenant_id")
  provider       PaymentProvider
  // Provider's id for the link/order. Unique per (tenant, provider).
  providerLinkId String            @map("provider_link_id")
  quotationId    String?           @map("quotation_id")
  leadId         String?           @map("lead_id")
  contactId      String            @map("contact_id")
  amount         Decimal           @db.Decimal(14, 2)
  currency       String            @db.VarChar(3)
  status         PaymentLinkStatus @default(CREATED)
  shortUrl       String?           @map("short_url")
  redirectUrl    String?           @map("redirect_url")
  expiresAt      DateTime?         @map("expires_at")
  paidAt         DateTime?         @map("paid_at")
  metadata       Json?
  createdById    String?           @map("created_by_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact              @relation(fields: [contactId], references: [id], onDelete: Cascade)
  quotation    Quotation?           @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  transactions PaymentTransaction[]
  invoices     Invoice[]

  @@unique([tenantId, provider, providerLinkId])
  @@index([tenantId, status])
  @@index([tenantId, leadId])
  @@index([tenantId, contactId])
  @@map("payment_links")
}

model PaymentTransaction {
  id                String           @id @default(cuid())
  tenantId          String           @map("tenant_id")
  paymentLinkId     String?          @map("payment_link_id")
  provider          PaymentProvider
  // Provider's payment / charge id. Unique per (tenant, provider) for
  // webhook idempotency.
  providerPaymentId String           @map("provider_payment_id")
  providerOrderId   String?          @map("provider_order_id")
  status            PaymentTxnStatus
  amount            Decimal          @db.Decimal(14, 2)
  feeAmount         Decimal?         @map("fee_amount") @db.Decimal(14, 2)
  taxOnFee          Decimal?         @map("tax_on_fee") @db.Decimal(14, 2)
  currency          String           @db.VarChar(3)
  method            String?
  // Raw provider payload for forensics. Already redacted by the provider
  // adapter (no card PANs, no CVVs — only what the provider returns).
  raw               Json
  capturedAt        DateTime?        @map("captured_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  link   PaymentLink? @relation(fields: [paymentLinkId], references: [id], onDelete: SetNull)

  @@unique([tenantId, provider, providerPaymentId])
  @@index([tenantId, status])
  @@index([providerPaymentId])
  @@index([paymentLinkId])
  @@map("payment_transactions")
}

model Invoice {
  id                   String    @id @default(cuid())
  tenantId             String    @map("tenant_id")
  number               String
  quotationId          String?   @map("quotation_id")
  paymentLinkId        String?   @map("payment_link_id")
  paymentTransactionId String?   @map("payment_transaction_id")
  pdfPath              String?   @map("pdf_path")
  amount               Decimal   @db.Decimal(14, 2)
  currency             String    @db.VarChar(3)
  sentAt               DateTime? @map("sent_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotation   Quotation?   @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  paymentLink PaymentLink? @relation(fields: [paymentLinkId], references: [id], onDelete: SetNull)

  @@unique([tenantId, number])
  @@index([tenantId, quotationId])
  @@map("invoices")
}
