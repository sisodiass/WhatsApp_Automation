# ─── Core ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# ─── Database (Postgres + pgvector) / Cache ──────────────────────────
DATABASE_URL=postgresql://sa:sa@localhost:5432/salesautomation
REDIS_URL=redis://localhost:6379

# ─── Secrets ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_me_with_64_byte_hex
# Generate with: openssl rand -hex 32  (must be exactly 32 bytes / 64 hex chars for AES-256-GCM)
ENCRYPTION_KEY=replace_me_with_32_byte_hex

# JWT lifetimes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── AI ───────────────────────────────────────────────────────────────
# Active provider is selected via the `ai.provider` setting (default: openai).
# Admin can switch providers at runtime from the Settings panel; the env vars
# below are the fallback values when matching settings rows are absent.

# OpenAI
OPENAI_API_KEY=sk-replace-me
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Gemini (Google AI Studio)
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# ─── Tenant (single-tenant per deploy; placeholder for future multi-tenant) ─
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_NAME=Default Tenant

# ─── Seed admin (used once on first seed) ────────────────────────────
# Must be a valid RFC email (TLD required) — the login validator rejects
# bare hostnames like "admin@local".
SEED_ADMIN_EMAIL=admin@local.test
# Leave blank to auto-generate a random password printed once to console
SEED_ADMIN_PASSWORD=

# ─── WhatsApp worker ─────────────────────────────────────────────────
# whatsapp-web.js downloads a Chromium build via puppeteer on first install.
# To use a system Chromium instead, set PUPPETEER_EXECUTABLE_PATH and run
# `npm install` with PUPPETEER_SKIP_DOWNLOAD=true.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_SKIP_DOWNLOAD=true
